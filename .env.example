# ─────────────────────────────────────────
# MESSAGE HUB BACKEND — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:8081

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Storage buckets (create these in Supabase dashboard)
SUPABASE_BUCKET_AVATARS=avatars
SUPABASE_BUCKET_COVERS=covers
SUPABASE_BUCKET_MESSAGES=messages
SUPABASE_BUCKET_STORIES=stories
SUPABASE_BUCKET_DOCUMENTS=documents
SUPABASE_BUCKET_THUMBNAILS=thumbnails

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Firebase (for FCM push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20

# File Upload Limits
MAX_FILE_SIZE_MB=100
MAX_IMAGE_SIZE_MB=20
MAX_VIDEO_SIZE_MB=100
MAX_AUDIO_SIZE_MB=25
MAX_DOCUMENT_SIZE_MB=50

# Story Settings
STORY_EXPIRY_HOURS=24

# Logging
LOG_LEVEL=info
